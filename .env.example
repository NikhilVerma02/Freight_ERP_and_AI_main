# LLM Gateway — organisational models (OpenAI-compatible / LiteLLM-style proxy)
API_ENDPOINT=your-gateway-endpoint-here
API_KEY=your-api-key-here

# ERP App (MCP Server)
ERP_HOST=127.0.0.1
ERP_PORT=8001
ERP_MCP_URL=http://127.0.0.1:8001/mcp

# AI App (MCP Client)
AI_HOST=127.0.0.1
AI_PORT=8002

# Auth
SESSION_SECRET=change-me-in-production

# ai-app claims pipeline — model role table (app/config/models.py). Every
# role is override-able here; defaults already point at organisational models.
MODEL_VISION=gemini-2.5-flash
MODEL_TRANSCRIBE=azure/genailab-maas-whisper
MODEL_EMBEDDING=azure/genailab-maas-text-embedding-3-large
MODEL_REASONING=azure_ai/Llama-3.3-70B-Instruct_Mass
MODEL_AGENT=azure/genailab-maas-gpt-4.1-mini
MODEL_FAST_SLM=azure/genailab-maas-gpt-4.1-nano
MODEL_CHAT=azure/genailab-maas-gpt-4.1
MODEL_TRANSLATE=azure/genailab-maas-gpt-4.1-nano

# SLA RAG (ERP vendor SLA Q&A) — same gateway, organisational models
RAG_CHAT_MODEL=azure_ai/Llama-3.3-70B-Instruct_Mass
RAG_EMBEDDING_MODEL=azure/genailab-maas-text-embedding-3-large
SLA_RAG_CHUNK_SIZE=800
SLA_RAG_CHUNK_OVERLAP=100
SLA_RAG_TOP_K=4

# Observability/Tracing — Langfuse Cloud free tier (https://cloud.langfuse.com)
# Sign up free, create a project, paste its keys here. Leave blank to disable
# tracing entirely (every call site no-ops gracefully without these).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
